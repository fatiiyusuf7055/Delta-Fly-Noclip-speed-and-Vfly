mR.MeshType = Enum.MeshType.Sphere
mR.Scale = Vector3.new(1.45, 1.35, 1.15)
mR.Parent = R
if shirt then mR.TextureId = shirt.ShirtTemplate end

local t = 0
while true do
    task.wait()
    t = t + 0.016
    if L.Parent and R.Parent and torso.Parent then
        L.CFrame = torso.CFrame * CFrame.new(-0.26, 0.05 + math.sin(t*9)*0.06, -0.55) * CFrame.Angles(0,0,math.rad(-10))
        R.CFrame = torso.CFrame * CFrame.new(0.26, 0.05 + math.sin(t*9+1)*0.06, -0.55) * CFrame.Angles(0,0,math.rad(10))
    end
