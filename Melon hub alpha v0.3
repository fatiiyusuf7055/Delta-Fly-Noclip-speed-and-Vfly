-- NoClip
noClipBtn.MouseButton1Click:Connect(function()
    noClip = not noClip
    noClipBtn.Text = "NoClip: "..(noClip and "ON" or "OFF")
    if noClip then
        setBtnOn(noClipBtn, noClipBs)
    else
        setBtnOff(noClipBtn, noClipBs)
        if char then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = true end
            end
        end
    end
end)
game:GetService("RunService").Stepped:Connect(function()
    if noClip and char then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

-- VFly
local vfly_bv
vflyBtn.MouseButton1Click:Connect(function()
    vfly_enabled = not vfly_enabled
    vflyBtn.Text = "VFly: "..(vfly_enabled and "ON" or "OFF")
    if vfly_enabled then
        setBtnOn(vflyBtn, vflyBs)
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then vfly_enabled = false return end
        if vfly_bv then vfly_bv:Destroy() end
        vfly_bv = Instance.new("BodyVelocity")
        vfly_bv.MaxForce = Vector3.new(0, 1e5, 0)
        vfly_bv.P = 1e5
        vfly_bv.Velocity = Vector3.new(0, 0, 0)
        vfly_bv.Parent = hrp
        task.spawn(function()
            while vfly_enabled do
                task.wait()
                if not char or not char:FindFirstChild("HumanoidRootPart") then break end
                local state = humanoid:GetState()
                if state == Enum.HumanoidStateType.Jumping then
                    vfly_bv.Velocity = Vector3.new(0, flySpeed * 10, 0)
                else
                    vfly_bv.Velocity = Vector3.new(0, 0, 0)
                end
            end
            if vfly_bv then vfly_bv:Destroy() vfly_bv = nil end
        end)
    else
        setBtnOff(vflyBtn, vflyBs)
        vfly_enabled = false
    end
end)

-- Fly
local fly_bv
flyBtn.MouseButton1Click:Connect(function()
    classicFly = not classicFly
    flyBtn.Text = "Fly: "..(classicFly and "ON" or "OFF")
    if classicFly then
        setBtnOn(flyBtn, flyBs)
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then classicFly = false return end
        if fly_bv then fly_bv:Destroy() end
        humanoid.WalkSpeed = 0
        fly_bv = Instance.new("BodyVelocity")
        fly_bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        fly_bv.P = 1e5
        fly_bv.Velocity = Vector3.new(0, 0, 0)
        fly_bv.Parent = hrp
        task.spawn(function()
            while classicFly do
                task.wait()
                if not char or not char:FindFirstChild("HumanoidRootPart") then break end
                local md = humanoid.MoveDirection
                local yVel = 0
                if humanoid:GetState() == Enum.HumanoidStateType.Jumping then
                    yVel = classicFlySpeed
                end
                if md.Magnitude > 0 then
                    fly_bv.Velocity = Vector3.new(md.X * classicFlySpeed, yVel, md.Z * classicFlySpeed)
                else
                    fly_bv.Velocity = Vector3.new(0, yVel, 0)
                end
            end
            if fly_bv then fly_bv:Destroy() fly_bv = nil end
            humanoid.WalkSpeed = speedEnabled and walkSpeed or 16
        end)
    else
        setBtnOff(flyBtn, flyBs)
        classicFly = false
    end
end)

-- Speed
speedBtn.MouseButton1Click:Connect(function()
    speedEnabled = not speedEnabled
    speedBtn.Text = "Speed: "..(speedEnabled and "ON" or "OFF")
    if speedEnabled then setBtnOn(speedBtn, speedBs) humanoid.WalkSpeed = walkSpeed
    else setBtnOff(speedBtn, speedBs) humanoid.WalkSpeed = 16 end
end)

-- Auto-Respawn
respawnBtn.MouseButton1Click:Connect(function()
    autoRespawn = not autoRespawn
    respawnBtn.Text = "⟳  Auto-Respawn "..(autoRespawn and "ON" or "OFF")
    if autoRespawn then setBtnOn(respawnBtn, respawnBs) else setBtnOff(respawnBtn, respawnBs) end
end)
player.CharacterRemoving:Connect(function()
    if not autoRespawn then return end
    local cam = workspace.CurrentCamera
    local savedType = cam.CameraType
    local savedCF = cam.CFrame
    cam.CameraType = Enum.CameraType.Scriptable
    cam.CFrame = savedCF
    task.wait(0.1)
    pcall(function() player:LoadCharacter() end)
    player.CharacterAdded:Wait()
    task.wait(0.1)
    cam.CameraType = savedType
end)

-- Kill
killBtn.MouseButton1Click:Connect(function()
    setBtnOn(killBtn, killBs)
    local c = player.Character
    if c then
        local hum = c:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end
    task.wait(0.4)
    setBtnOff(killBtn, killBs)
end)

-- Inf Jump
infJumpBtn.MouseButton1Click:Connect(function()
