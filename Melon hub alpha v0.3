local mL = Instance.new("SpecialMesh")
mL.MeshType = Enum.MeshType.Sphere
mL.Scale = Vector3.new(1.45, 1.35, 1.15)
mL.Parent = L
local shirt = char:FindFirstChildOfClass("Shirt")
if shirt then mL.TextureId = shirt.ShirtTemplate end

local R = Instance.new("Part")
