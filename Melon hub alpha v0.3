local function makeSep(y)
    local s = Instance.new("Frame")
    s.Size = UDim2.new(1, -20, 0, 1)
    s.Position = UDim2.new(0, 10, 0, y)
    s.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    s.BorderSizePixel = 0
    s.Parent = frame
end

local function makeBtn(txt, y)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 36)
    btn.Position = UDim2.new(0, 10, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    btn.BorderSizePixel = 0
    btn.Text = txt
    btn.TextColor3 = Color3.fromRGB(210, 210, 210)
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamBold
    btn.Parent = frame
    local bc = Instance.new("UICorner")
    bc.CornerRadius = UDim.new(0, 8)
    bc.Parent = btn
    local bs = Instance.new("UIStroke")
    bs.Color = Color3.fromRGB(55, 55, 55)
    bs.Thickness = 1
    bs.Parent = btn
    return btn, bs
end

local function makeInput(lbl, y, startVal, callback)
    local lbEl = Instance.new("TextLabel")
    lbEl.Size = UDim2.new(0, 125, 0, 24)
    lbEl.Position = UDim2.new(0, 10, 0, y)
    lbEl.BackgroundTransparency = 1
    lbEl.Text = lbl
    lbEl.TextColor3 = Color3.fromRGB(150, 150, 150)
    lbEl.TextSize = 12
    lbEl.Font = Enum.Font.Gotham
    lbEl.TextXAlignment = Enum.TextXAlignment.Left
    lbEl.Parent = frame
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0, 65, 0, 24)
    box.Position = UDim2.new(1, -78, 0, y)
    box.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    box.BorderSizePixel = 0
    box.Text = tostring(startVal)
    box.TextColor3 = Color3.fromRGB(210, 210, 210)
    box.TextSize = 12
    box.Font = Enum.Font.GothamBold
    box.ClearTextOnFocus = false
    box.Parent = frame
    local bCorner = Instance.new("UICorner")
    bCorner.CornerRadius = UDim.new(0, 6)
    bCorner.Parent = box
    local bStroke = Instance.new("UIStroke")
    bStroke.Color = Color3.fromRGB(55, 55, 55)
    bStroke.Thickness = 1
    bStroke.Parent = box
    box.FocusLost:Connect(function()
        local v = tonumber(box.Text)
        if v then callback(v) else box.Text = tostring(startVal) end
    end)
end

local function setBtnOn(btn, bs)
    btn.BackgroundColor3 = Color3.fromRGB(160, 25, 25)
    bs.Color = Color3.fromRGB(220, 55, 55)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
end
local function setBtnOff(btn, bs)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    bs.Color = Color3.fromRGB(55, 55, 55)
    btn.TextColor3 = Color3.fromRGB(210, 210, 210)
end

